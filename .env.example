APP_NAME=JB API
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_BASE_ROUTE=/api
ROUTE_CACHE_ENABLED=false
ROUTE_CACHE_PATH=storage/cache/routes.json

CORS_ALLOWED_ORIGINS=*

DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jb
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_PATH=storage/database.sqlite

JWT_SECRET=change-me
JWT_TTL=3600
JWT_REFRESH_TTL=1209600

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60

SECURITY_ENABLED=true
SECURITY_LEARNING_MODE=false
SECURITY_FAIL_OPEN=true
