{
    "name": "jb/framework",
    "description": "Miniframework PHP 8.2 para APIs REST.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Jb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jb\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/jb"
    ],
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite Unit",
        "test-integration": "phpunit --testsuite Integration"
    },
    "config": {
        "sort-packages": true
    }
}
